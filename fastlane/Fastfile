  lane :metadata do
    ENV["FASTLANE_ENABLE_BETA_DELIVER_SYNC_SCREENSHOTS"] = "true"
    deliver(
      api_key:              api_key,
      app_identifier:       BUNDLE_ID,
      skip_binary_upload:   true,
      skip_screenshots:     false,
      screenshots_path:     "appstore/screenshots",
      metadata_path:        "fastlane/metadata",
      submit_for_review:    false,
      force:                true,
      overwrite_screenshots: true,
      sync_screenshots:     false,
      copyright:            "2026 priroda.tech",
      support_url:          { "en-US" => "https://professormadrid.com" },
      primary_category:     "EDUCATION",
      app_rating_config_path: "fastlane/metadata/app_rating_config.json",
      precheck_include_in_app_purchases: false,
      app_review_information: {
        first_name:         "Andrii",
        last_name:          "Chepizhko",
        phone_number:       "+380 68 072 1898",
        email_address:      "support-professormadrid@priroda.tech",
        demo_user:          "",
        demo_password:      "",
        notes:              "ACCOUNT: Sign in with Apple (or Google) is required to reach the app - use the built-in Sign in with Apple button with any Apple ID. No demo account needed; creating an account is free.\n\n" \
                             "AI DISCLOSURE: Immediately after sign-in, every user (new and returning) sees a dedicated screen explaining exactly what data is sent to which third-party AI service, before anything is sent: voice recordings -> OpenAI (transcription only); chat messages and Street View photos -> OpenAI; the tutor's spoken replies -> mainly Google's text-to-speech, with OpenAI used only as an automatic backup if Google's service is briefly unavailable; onboarding-quiz answers -> Google Gemini. The user must tap 'I Understand & Continue' before any of this happens. This is separate from, and in addition to, the Privacy Policy.\n\n" \
                             "BUSINESS MODEL / IN-APP PURCHASES: Every new account automatically receives a one-time free grant of \"treats\" (our in-app virtual credit) so every AI feature can be fully tested without paying. There is no recurring free daily allowance for anything - treats are required for: AI tutor chat replies (~5 treats), spoken/voice replies (~2 treats), asking the tutor about a Street View photo (~9 treats), identifying/labelling objects in a Street View photo (~6 treats), adding a word or phrase to the Memorise queue which generates its repeat-audio and picture (~3 treats), and checking a spoken answer in the Verbs & Times game (~2 treats). Signing in, reviewing past sessions, and reviewing already-learned words in Memorise are free and not gated by treats. ENFORCEMENT: the server checks the treat balance BEFORE calling any AI provider - if insufficient, the action is blocked outright (no AI request is made, so nothing is charged for a request that didn't happen) and the app shows an inline message ('You're out of treats. Top up to keep going.') directing the user to purchase more. Additional treats can be purchased from Profile -> tap the treats balance -> \"Get Treats\" screen, which sells three CONSUMABLE (non-subscription) treat packs via StoreKit In-App Purchase only - no external purchase link, no web checkout. That screen explicitly states \"Treats never expire. One-time purchase - no subscription,\" and tapping \"Full pricing details\" there opens a complete breakdown of exactly what each action costs. The same screen also has an optional promo-code field: codes only ever grant FREE bonus treats (a marketing gift, same category as the automatic free-trial grant) - no money changes hands outside Apple's IAP through that field. Full legal detail mirroring all of the above, including the exact per-feature costs, is in Terms & Conditions section 4 (\"Treats, Billing & Payments\") at https://professormadrid.com/terms."
      }
    )
  end

  desc "Declare App Privacy nutrition labels via App Store Connect API"
  lane :privacy_labels do
    require "net/http"
    require "uri"
    require "json"
    require "openssl"
    require "jwt"

    private_key = OpenSSL::PKey::EC.new(File.read(KEY_PATH))
    now  = Time.now.to_i
    token = JWT.encode(
      { iss: ISSUER_ID, iat: now, exp: now + 1200, aud: "appstoreconnect-v1" },
      private_key, "ES256",
      { kid: KEY_ID }
    )

    base    = "https://api.appstoreconnect.apple.com/v1"
    headers = { "Authorization" => "Bearer #{token}", "Content-Type" => "application/json" }

    # What we collect and why:
    #
    #   AUDIO_DATA       Voice recordings sent to server for transcription (OpenAI).
    #                    Processed server-side and immediately discarded; never stored.
    #                    → NOT linked to user identity, NOT tracked.
    #
    #   PHOTOS_OR_VIDEOS Photos sent to server for Street View AI annotation (OpenAI vision).
    #                    Processed server-side and immediately discarded; never stored.
    #                    → NOT linked to user identity, NOT tracked.
    #
    #   EMAIL_ADDRESS    Collected at Apple/Google sign-in; stored in Supabase auth + profiles.
    #                    Used to identify the account.
    #                    → LINKED to user identity, NOT tracked.
    #
    #   NAME             Display name from Apple/Google sign-in; stored in profiles table.
    #                    Used for the in-app profile display name.
    #                    → LINKED to user identity, NOT tracked.
    #
    #   USER_ID          Supabase UUID assigned at sign-in; stored in all user tables.
    #                    Drives the treat wallet, session history, and memory cards.
    #                    → LINKED to user identity, NOT tracked.

    usages = [
      { dataCategory: "AUDIO_DATA",        linkedToUser: false, dataTracked: false, purposes: ["APP_FUNCTIONALITY"] },
      { dataCategory: "PHOTOS_OR_VIDEOS",  linkedToUser: false, dataTracked: false, purposes: ["APP_FUNCTIONALITY"] },
      { dataCategory: "EMAIL_ADDRESS",      linkedToUser: true,  dataTracked: false, purposes: ["APP_FUNCTIONALITY"] },
      { dataCategory: "NAME",               linkedToUser: true,  dataTracked: false, purposes: ["APP_FUNCTIONALITY"] },
      { dataCategory: "USER_ID",            linkedToUser: true,  dataTracked: false, purposes: ["APP_FUNCTIONALITY"] },
    ]

    usages.each do |usage|
      body = {
        data: {
          type: "appDataUsages",
          attributes: {
            dataCategory: usage[:dataCategory],
            dataLinked:   usage[:linkedToUser],
            dataTracked:  usage[:dataTracked]
          },
          relationships: {
            app: {
              data: { type: "apps", id: APPLE_ID }
            },
            purposes: {
              data: usage[:purposes].map { |p| { type: "appDataUsagePurposes", id: p } }
            }
          }
        }
      }

      uri = URI("#{base}/appDataUsages")
      req = Net::HTTP::Post.new(uri)
      headers.each { |k, v| req[k] = v }
      req.body = JSON.generate(body)

      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }

      case resp.code.to_i
      when 201
        UI.success("✅  Declared #{usage[:dataCategory]}")
      when 409
        UI.message("⚠️   #{usage[:dataCategory]} already declared — skipping")
      else
        UI.error("❌  #{usage[:dataCategory]}: HTTP #{resp.code}\n#{resp.body[0..400]}")
      end
    end
  end

  desc "Set IAP metadata (name + description) and pricing (USD base, auto-equalized globally)"
  lane :iap_setup do
    require "net/http"
    require "uri"
    require "json"
    require "openssl"
    require "jwt"

    private_key = OpenSSL::PKey::EC.new(File.read(KEY_PATH))
    now   = Time.now.to_i
    token = JWT.encode(
      { iss: ISSUER_ID, iat: now, exp: now + 1200, aud: "appstoreconnect-v1" },
      private_key, "ES256",
      { kid: KEY_ID }
    )

    base_v1 = "https://api.appstoreconnect.apple.com/v1"
    base_v2 = "https://api.appstoreconnect.apple.com/v2"
    headers  = { "Authorization" => "Bearer #{token}", "Content-Type" => "application/json" }

    asc_get = lambda do |url|
      uri  = URI(url)
      req  = Net::HTTP::Get.new(uri)
      headers.each { |k, v| req[k] = v }
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      JSON.parse(resp.body)
    end

    asc_post = lambda do |url, body|
      uri  = URI(url)
      req  = Net::HTTP::Post.new(uri)
      headers.each { |k, v| req[k] = v }
      req.body = JSON.generate(body)
      resp   = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      parsed = begin; JSON.parse(resp.body); rescue; {}; end
      [resp.code.to_i, parsed]
    end

    asc_patch = lambda do |url, body|
      uri  = URI(url)
      req  = Net::HTTP::Patch.new(uri)
      headers.each { |k, v| req[k] = v }
      req.body = JSON.generate(body)
      resp   = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      parsed = begin; JSON.parse(resp.body); rescue; {}; end
      [resp.code.to_i, parsed]
    end

    packs = {
      "treats_starter_599"  => { name: "Starter Pack", description: "599 treats to keep your Spanish lessons going.", usd: "5.99" },
      "treats_plus_1199"    => { name: "Plus Pack",    description: "1,379 treats — 15% bonus for regular learners.", usd: "11.99" },
      "treats_pro_2499"     => { name: "Pro Pack",     description: "3,124 treats — 25% bonus. Go deeper.",           usd: "24.99" },
    }

    UI.message("Fetching IAP list for app #{APPLE_ID}...")
    iap_resp = asc_get.call("#{base_v1}/apps/#{APPLE_ID}/inAppPurchasesV2?limit=50")
    iaps = (iap_resp["data"] || [])

    if iaps.empty?
      UI.error("No IAPs found — check APPLE_ID or API key permissions")
      next
    end

    iaps.each do |iap|
      product_id = iap.dig("attributes", "productId") || iap.dig("attributes", "referenceName") || ""
      iap_id     = iap["id"]
      pack       = packs[product_id]

      unless pack
        UI.message("⚠️  Skipping unrecognised product_id '#{product_id}' (id: #{iap_id})")
        next
      end

      UI.message("\n── #{pack[:name]} (#{product_id}) id=#{iap_id}")

      # 1. Check for existing localizations via v2 path
      locs_url  = "#{base_v2}/inAppPurchases/#{iap_id}/inAppPurchaseLocalizations"
      locs_resp = asc_get.call(locs_url)
      locs      = locs_resp["data"] || []
      existing  = locs.find { |l| l.dig("attributes", "locale") == "en-US" }

      if existing
        # PATCH the existing localization
        loc_id   = existing["id"]
        patch_body = {
          data: {
            type: "inAppPurchaseLocalizations",
            id:   loc_id,
            attributes: { name: pack[:name], description: pack[:description] }
          }
        }
        code, presp = asc_patch.call("#{base_v2}/inAppPurchaseLocalizations/#{loc_id}", patch_body)
        case code
        when 200
          UI.success("  ✅  Localization updated (id=#{loc_id})")
        else
          errs = (presp["errors"] || []).map { |e| "#{e['code']}: #{e['detail']}" }.join("; ")
          UI.error("  ❌  PATCH localization HTTP #{code}: #{errs}")
        end
      else
        # POST a new localization using v2 endpoint + inAppPurchases type
        loc_body = {
          data: {
            type: "inAppPurchaseLocalizations",
            attributes: { locale: "en-US", name: pack[:name], description: pack[:description] },
            relationships: {
              inAppPurchaseV2: { data: { type: "inAppPurchases", id: iap_id } }
            }
          }
        }
        code, _resp = asc_post.call("#{base_v2}/inAppPurchaseLocalizations", loc_body)
        case code
        when 201
          loc_id = _resp.dig("data", "id")
          UI.success("  ✅  Localization created (id=#{loc_id})")
        when 409
          errs = (_resp["errors"] || []).map { |e| "#{e['code']}: #{e['detail']}" }.join(" | ")
          UI.message("  ⚠️   409: #{errs}")
        when 422
          errs = (_resp["errors"] || []).map { |e| "#{e['code']}: #{e['detail']}" }.join("; ")
          UI.error("  ❌  422: #{errs}")
        else
          UI.error("  ❌  HTTP #{code}: #{JSON.generate(_resp)[0..300]}")
        end
      end

    end

    UI.important("\n" + ("─" * 60))
    UI.important("  IAP PRICING — manual step required")
    UI.important("─" * 60)
    UI.important("  The App Store Connect API restricts inAppPurchasePricePoints")
    UI.important("  to Finance-role API keys. Our key is App Manager (sufficient")
    UI.important("  for submission/metadata but not pricing). Set each pack price")
    UI.important("  manually in App Store Connect → Your App → In-App Purchases:")
    UI.important("")
    packs.each do |pid, pack|
      UI.important("  • #{pack[:name].ljust(14)} (#{pid.ljust(12)})  →  $#{pack[:usd]} USD")
    end
    UI.important("")
    UI.important("  For each product:")
    UI.important("  1. Click the product name")
    UI.important("  2. Under Pricing, click 'Add Pricing'")
    UI.important("  3. Base country: United States  →  $X.XX")
    UI.important("  4. ✓ 'Automatically recalculate prices for all other countries'")
    UI.important("  5. Save")
    UI.important("─" * 60)

    UI.success("\n🏁  IAP localization complete. Pricing requires 4 manual steps above.")
  end

  desc "Diagnose what is missing for each IAP (state, localizations, pricing, review screenshot)"
  lane :iap_diagnose do
    require "net/http"
    require "uri"
    require "json"
    require "openssl"
    require "jwt"

    private_key = OpenSSL::PKey::EC.new(File.read(KEY_PATH))
    now   = Time.now.to_i
    token = JWT.encode(
      { iss: ISSUER_ID, iat: now, exp: now + 1200, aud: "appstoreconnect-v1" },
      private_key, "ES256",
      { kid: KEY_ID }
    )
    base    = "https://api.appstoreconnect.apple.com/v1"
    headers = { "Authorization" => "Bearer #{token}" }

    asc_get = lambda do |path|
      url  = path.start_with?("http") ? path : "#{base}#{path}"
      uri  = URI(url)
      req  = Net::HTTP::Get.new(uri)
      headers.each { |k, v| req[k] = v }
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      JSON.parse(resp.body)
    end

    iaps = (asc_get.call("/apps/#{APPLE_ID}/inAppPurchasesV2?limit=50")["data"] || [])

    if iaps.empty?
      UI.error("No IAPs found")
      next
    end

    UI.important("\n#{"─" * 60}")
    UI.important("  IAP Full Diagnostic")
    UI.important("─" * 60)

    iaps.each do |iap|
      iap_id = iap["id"]
      pid    = iap.dig("attributes", "productId") || iap_id
      state  = iap.dig("attributes", "state") || "UNKNOWN"
      UI.message("\n▶ #{pid}  (id: #{iap_id})  state=#{state}")

      # Check localizations via v2 path
      locs = asc_get.call("https://api.appstoreconnect.apple.com/v2/inAppPurchases/#{iap_id}/inAppPurchaseLocalizations")
      loc_data = locs["data"] || []
      if loc_data.empty?
        UI.error("  ❌ No localizations — run bundle exec fastlane iap_setup")
      else
        loc_data.each do |l|
          name   = l.dig("attributes", "name") || "(no name)"
          locale = l.dig("attributes", "locale") || "?"
          lstate = l.dig("attributes", "state") || "?"
          UI.success("  ✅ Localization [#{locale}] '#{name}' state=#{lstate}")
        end
      end

      # Check pricing schedule via v2 path
      sched = asc_get.call("https://api.appstoreconnect.apple.com/v2/inAppPurchases/#{iap_id}/iapPriceSchedule?include=manualPrices")
      if sched["errors"]
        errs = sched["errors"].map { |e| "#{e['status']}: #{e['title']}" }.join("; ")
        UI.error("  ❌ Pricing schedule: #{errs}")
      else
        manual = (sched.dig("included") || []).select { |r| r["type"] == "iapManualPrices" || r["type"] == "inAppPurchaseManualPrices" }
        usd = manual.find { |m| m.dig("attributes", "territory") == "USA" }
        if usd
          price = usd.dig("attributes", "customerPrice") || "?"
          UI.success("  ✅ USD price set: $#{price}")
        else
          UI.error("  ❌ No USD price set — set in App Store Connect → In-App Purchases → #{pid} → Pricing")
        end
        UI.message("  ℹ️  #{manual.size} territories have manual prices")
      end
    end

    UI.important("\n#{"─" * 60}")
  end

  desc "Create a new review submission for the rejected v1.0 version, linking all 3 IAPs"
  lane :resubmit_with_iaps do
    require "net/http"
    require "uri"
    require "json"
    require "openssl"
    require "jwt"

    private_key = OpenSSL::PKey::EC.new(File.read(KEY_PATH))
    now   = Time.now.to_i
    token = JWT.encode(
      { iss: ISSUER_ID, iat: now, exp: now + 1200, aud: "appstoreconnect-v1" },
      private_key, "ES256", { kid: KEY_ID }
    )
    base    = "https://api.appstoreconnect.apple.com/v1"
    headers = { "Authorization" => "Bearer #{token}", "Content-Type" => "application/json" }

    asc_get = lambda do |path|
      uri  = URI("#{base}#{path}")
      req  = Net::HTTP::Get.new(uri)
      headers.each { |k, v| req[k] = v }
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      JSON.parse(resp.body)
    end

    asc_post = lambda do |path, body|
      uri  = URI("#{base}#{path}")
      req  = Net::HTTP::Post.new(uri)
      headers.each { |k, v| req[k] = v }
      req.body = JSON.generate(body)
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      parsed = begin; JSON.parse(resp.body); rescue; {}; end
      [resp.code.to_i, parsed]
    end

    asc_patch = lambda do |path, body|
      uri  = URI("#{base}#{path}")
      req  = Net::HTTP::Patch.new(uri)
      headers.each { |k, v| req[k] = v }
      req.body = JSON.generate(body)
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      parsed = begin; JSON.parse(resp.body); rescue; {}; end
      [resp.code.to_i, parsed]
    end

    # 1. Find the REJECTED version
    UI.message("Looking for REJECTED version...")
    all_v = asc_get.call("/apps/#{APPLE_ID}/appStoreVersions?filter%5Bplatform%5D=IOS&limit=10")
    version = (all_v["data"] || []).find { |v| %w[REJECTED PREPARE_FOR_SUBMISSION WAITING_FOR_REVIEW DEVELOPER_REJECTED].include?(v.dig("attributes", "appStoreState")) }

    if version.nil?
      UI.error("No editable version found. All versions are approved or in a terminal state.")
      next
    end

    version_id  = version["id"]
    version_str = version.dig("attributes", "versionString") || "?"
    state       = version.dig("attributes", "appStoreState")
    UI.success("Found version #{version_str} in state #{state} (id: #{version_id})")

    # 2. Check IAPs are all ready
    UI.message("Checking IAP states...")
    iap_resp = asc_get.call("/apps/#{APPLE_ID}/inAppPurchasesV2?limit=50")
    iaps = iap_resp["data"] || []

    known_ids = %w[treats_starter_599 treats_plus_1199 treats_pro_2499]
    our_iaps  = iaps.select { |i| known_ids.include?(i.dig("attributes", "productId")) }

    not_ready = our_iaps.reject { |i| %w[READY_TO_SUBMIT WAITING_FOR_REVIEW IN_REVIEW APPROVED READY_FOR_SALE].include?(i.dig("attributes", "state")) }

    if not_ready.any?
      UI.error("The following IAPs are NOT ready to submit:")
      not_ready.each { |i| UI.error("  ❌  #{i.dig('attributes','productId')} → #{i.dig('attributes','state')}") }
      UI.error("\nTo fix: Open each IAP in App Store Connect → Pricing → set USD price → Save.")
      UI.error("Then re-run: bundle exec fastlane resubmit_with_iaps")
      next
    end

    UI.success("All #{our_iaps.size} IAPs are ready to submit ✅")

    # 3. Find or create a submittable review submission
    UI.message("Checking for existing review submissions...")
    subs_resp  = asc_get.call("/apps/#{APPLE_ID}/reviewSubmissions?limit=10")
    all_subs   = subs_resp["data"] || []
    submission_id = nil

    # Prefer an existing UNRESOLVED_ISSUES or READY_FOR_REVIEW submission (already has version+IAPs linked)
    reusable = all_subs.find { |s| %w[UNRESOLVED_ISSUES READY_FOR_REVIEW].include?(s.dig("attributes", "state")) }
    if reusable
      submission_id = reusable["id"]
      UI.success("Reusing existing submission #{submission_id} (state: #{reusable.dig('attributes','state')})")
    else
      UI.message("No reusable submission found — creating new one...")
      code, sub_resp = asc_post.call("/reviewSubmissions", {
        data: {
          type: "reviewSubmissions",
          attributes: { platform: "IOS" },
          relationships: { app: { data: { type: "apps", id: APPLE_ID } } }
        }
      })
      unless [200, 201].include?(code)
        errs = (sub_resp["errors"] || []).map { |e| e["detail"] || e["title"] }.join("; ")
        UI.error("Failed to create review submission: HTTP #{code}: #{errs}")
        next
      end
      submission_id = sub_resp.dig("data", "id")
      UI.success("Created review submission #{submission_id}")

      # Add the app version
      UI.message("Adding app version #{version_str} to review submission...")
      code, item_resp = asc_post.call("/reviewSubmissionItems", {
        data: {
          type: "reviewSubmissionItems",
          relationships: {
            reviewSubmission: { data: { type: "reviewSubmissions", id: submission_id } },
            appStoreVersion:  { data: { type: "appStoreVersions",  id: version_id } }
          }
        }
      })
      case code
      when 200, 201 then UI.success("  ✅  App version added (item id: #{item_resp.dig('data','id')})")
      when 409      then UI.message("  ⚠️   Version already in a submission")
      else
        errs = (item_resp["errors"] || []).map { |e| e["detail"] || e["title"] }.join("; ")
        UI.error("  ❌  HTTP #{code}: #{errs}")
      end

      # Add each IAP
      our_iaps.each do |iap|
        pid    = iap.dig("attributes", "productId")
        iap_id = iap["id"]
        next if %w[WAITING_FOR_REVIEW IN_REVIEW APPROVED READY_FOR_SALE].include?(iap.dig("attributes", "state"))

        UI.message("Adding IAP #{pid}...")
        code, item_resp = asc_post.call("/reviewSubmissionItems", {
          data: {
            type: "reviewSubmissionItems",
            relationships: {
              reviewSubmission: { data: { type: "reviewSubmissions", id: submission_id } },
              inAppPurchaseV2:  { data: { type: "inAppPurchasesV2",  id: iap_id } }
            }
          }
        })
        case code
        when 200, 201 then UI.success("  ✅  #{pid} added")
        when 409      then UI.message("  ⚠️   #{pid} already in submission")
        else
          errs = (item_resp["errors"] || []).map { |e| e["detail"] || e["title"] }.join("; ")
          UI.error("  ❌  #{pid} HTTP #{code}: #{errs}")
        end
      end
    end

    # 4. Inspect submission items before submitting
    UI.message("Fetching submission items for #{submission_id}...")
    items_resp = asc_get.call("/reviewSubmissions/#{submission_id}/items")
    items = items_resp["data"] || []
    UI.message("  #{items.size} item(s) in submission:")
    items.each { |i| UI.message("    type=#{i['type']} id=#{i['id']} state=#{i.dig('attributes','state')}") }

    # 5. Submit the review submission
    UI.message("Submitting review submission #{submission_id} for review...")
    code, final_resp = asc_patch.call("/reviewSubmissions/#{submission_id}", {
      data: {
        type: "reviewSubmissions",
        id:   submission_id,
        attributes: { submitted: true }
      }
    })
    case code
    when 200, 201
      UI.success("✅  Successfully submitted for App Review!")
      UI.success("    Submission ID: #{submission_id}")
    else
      errs = (final_resp["errors"] || []).map { |e| e["detail"] || e["title"] }.join("; ")
      UI.error("❌  Failed to submit: HTTP #{code}: #{errs}")
      UI.message("    Full response: #{JSON.generate(final_resp)[0..600]}")
    end
  end

  lane :link_iaps do
    require "net/http"
    require "uri"
    require "json"
    require "openssl"
    require "jwt"

    private_key = OpenSSL::PKey::EC.new(File.read(KEY_PATH))
    now   = Time.now.to_i
    token = JWT.encode(
      { iss: ISSUER_ID, iat: now, exp: now + 1200, aud: "appstoreconnect-v1" },
      private_key, "ES256",
      { kid: KEY_ID }
    )

    base    = "https://api.appstoreconnect.apple.com/v1"
    headers = { "Authorization" => "Bearer #{token}", "Content-Type" => "application/json" }

    asc_get = lambda do |path|
      uri  = URI("#{base}#{path}")
      req  = Net::HTTP::Get.new(uri)
      headers.each { |k, v| req[k] = v }
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      JSON.parse(resp.body)
    end

    asc_post = lambda do |path, body|
      uri  = URI("#{base}#{path}")
      req  = Net::HTTP::Post.new(uri)
      headers.each { |k, v| req[k] = v }
      req.body = JSON.generate(body)
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      parsed = begin; JSON.parse(resp.body); rescue; {}; end
      [resp.code.to_i, parsed]
    end

    # 1. Get the current editable version (PREPARE_FOR_SUBMISSION)
    UI.message("Fetching current editable version for app #{APPLE_ID}...")
    versions_resp = asc_get.call("/apps/#{APPLE_ID}/appStoreVersions?filter%5Bplatform%5D=IOS&filter%5BappStoreState%5D=PREPARE_FOR_SUBMISSION&limit=5")
    versions = versions_resp["data"] || []

    if versions.empty?
      UI.error("No version in PREPARE_FOR_SUBMISSION state found.")
      UI.error("Response: #{JSON.generate(versions_resp)[0..400]}")
      next
    end

    version = versions.first
    version_id = version["id"]
    version_str = version.dig("attributes", "versionString") || "?"
    UI.success("Found version #{version_str} (id: #{version_id})")

    # 2. Fetch all IAPs and their current state
    UI.message("Fetching IAP list...")
    iap_resp = asc_get.call("/apps/#{APPLE_ID}/inAppPurchasesV2?limit=50")
    iaps = iap_resp["data"] || []

    if iaps.empty?
      UI.error("No IAPs found.")
      next
    end

    UI.message("Found #{iaps.size} IAPs:")
    iaps.each do |iap|
      pid   = iap.dig("attributes", "productId") || iap["id"]
      state = iap.dig("attributes", "state") || "UNKNOWN"
      UI.message("  #{pid.ljust(16)} state=#{state}")
    end

    # 3. Submit each IAP for review via inAppPurchaseSubmissions.
    #    This is the correct API flow — Apple links them to the pending version automatically.
    #    IAPs must be in MISSING_METADATA or READY_FOR_SUBMISSION state.
    #    If they are DRAFT/WAITING_FOR_REVIEW they will be skipped gracefully.
    submitted = 0
    skipped   = 0

    iaps.each do |iap|
      iap_id  = iap["id"]
      pid     = iap.dig("attributes", "productId") || iap_id
      state   = iap.dig("attributes", "state") || ""

      if state == "WAITING_FOR_REVIEW" || state == "IN_REVIEW" || state == "APPROVED" || state == "READY_FOR_SALE"
        UI.message("  ⏭  #{pid} already submitted/approved (state: #{state}) — skipping")
        skipped += 1
        next
      end

      body = {
        data: {
          type: "inAppPurchaseSubmissions",
          relationships: {
            inAppPurchaseV2: { data: { type: "inAppPurchaseV2", id: iap_id } }
          }
        }
      }
      code, resp_body = asc_post.call("/inAppPurchaseSubmissions", body)

      case code
      when 200, 201
        UI.success("  ✅  #{pid} submitted for review")
        submitted += 1
      when 409
        UI.message("  ⚠️   #{pid} already submitted — skipping")
        skipped += 1
      else
        errors = (resp_body["errors"] || []).map { |e| (e["detail"] || e["title"] || "").strip }.join("; ")
        UI.error("  ❌  #{pid} HTTP #{code}: #{errors}")
        if errors.include?("pricing") || errors.include?("price") || state == "MISSING_METADATA"
          UI.error("      → Pricing is not set. Set $USD price in App Store Connect first,")
          UI.error("        then re-run: bundle exec fastlane link_iaps")
        end
      end
    end

    UI.important("\n#{submitted} submitted, #{skipped} skipped.")
    if submitted > 0
      UI.success("✅  IAPs are now submitted for review alongside version #{version_str}.")
      UI.success("    You can now run: bundle exec fastlane submit")
    end
  end

  desc "Delete pending IAP submissions so localizations/pricing can be edited again"
  lane :iap_reset do
    require "net/http"
    require "uri"
    require "json"
    require "openssl"
    require "jwt"

    private_key = OpenSSL::PKey::EC.new(File.read(KEY_PATH))
    now   = Time.now.to_i
    token = JWT.encode(
      { iss: ISSUER_ID, iat: now, exp: now + 1200, aud: "appstoreconnect-v1" },
      private_key, "ES256",
      { kid: KEY_ID }
    )
    base    = "https://api.appstoreconnect.apple.com/v1"
    headers = { "Authorization" => "Bearer #{token}", "Content-Type" => "application/json" }

    asc_get = lambda do |path|
      uri  = URI("#{base}#{path}")
      req  = Net::HTTP::Get.new(uri)
      headers.each { |k, v| req[k] = v }
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      JSON.parse(resp.body)
    end

    asc_delete = lambda do |path|
      uri  = URI("#{base}#{path}")
      req  = Net::HTTP::Delete.new(uri)
      headers.each { |k, v| req[k] = v }
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      resp.code.to_i
    end

    iaps = (asc_get.call("/apps/#{APPLE_ID}/inAppPurchasesV2?limit=50")["data"] || [])
    if iaps.empty?
      UI.error("No IAPs found")
      next
    end

    iaps.each do |iap|
      iap_id = iap["id"]
      pid    = iap.dig("attributes", "productId") || iap_id
      UI.message("\n── #{pid} (#{iap_id})")

      # Fetch and delete any pending submissions
      subs = asc_get.call("/inAppPurchasesV2/#{iap_id}/inAppPurchaseSubmission")
      sub_data = subs["data"]
      if sub_data
        sub_id = sub_data["id"]
        UI.message("  Deleting submission #{sub_id}...")
        code = asc_delete.call("/inAppPurchaseSubmissions/#{sub_id}")
        case code
        when 204
          UI.success("  ✅  Submission deleted — IAP is editable again")
        when 404
          UI.message("  ℹ️  No active submission found")
        else
          UI.error("  ❌  DELETE submission HTTP #{code}")
        end
      else
        errs = (subs["errors"] || []).map { |e| "#{e['status']}: #{e['title']}" }.join("; ")
        UI.message("  ℹ️  No submission: #{errs.empty? ? 'none found' : errs}")
      end
    end

    UI.success("\nDone. Now run: bundle exec fastlane iap_setup")
    UI.success("Then set pricing manually in App Store Connect, then run: bundle exec fastlane link_iaps")
  end

  desc "Check localizations via v1 IAP path (the actual path for these IAPs)"
  lane :iap_check_locs do
    require "net/http"
    require "uri"
    require "json"
    require "openssl"
    require "jwt"

    private_key = OpenSSL::PKey::EC.new(File.read(KEY_PATH))
    now   = Time.now.to_i
    token = JWT.encode(
      { iss: ISSUER_ID, iat: now, exp: now + 1200, aud: "appstoreconnect-v1" },
      private_key, "ES256", { kid: KEY_ID }
    )
    base    = "https://api.appstoreconnect.apple.com/v1"
    headers = { "Authorization" => "Bearer #{token}" }

    asc_get = lambda do |path|
      uri  = URI("#{base}#{path}")
      req  = Net::HTTP::Get.new(uri)
      headers.each { |k, v| req[k] = v }
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      [resp.code.to_i, JSON.parse(resp.body)]
    end

    _, iap_resp = asc_get.call("/apps/#{APPLE_ID}/inAppPurchasesV2?limit=50")
    iaps = iap_resp["data"] || []
    next UI.error("No IAPs found") if iaps.empty?

    iaps.each do |iap|
      iap_id = iap["id"]
      pid    = iap.dig("attributes", "productId") || iap_id
      UI.message("\n▶ #{pid} (#{iap_id})")

      # Localizations via v1 path
      code, parsed = asc_get.call("/inAppPurchases/#{iap_id}/inAppPurchaseLocalizations")
      locs = parsed["data"] || []
      errs = (parsed["errors"] || []).map { |e| "#{e['status']}: #{e['title']}" }.join("; ")
      if code == 200 && !locs.empty?
        locs.each do |l|
          UI.success("  ✅ [#{l.dig('attributes','locale')}] name='#{l.dig('attributes','name')}' desc='#{(l.dig('attributes','description') || '')[0..40]}' state=#{l.dig('attributes','state')}")
        end
      else
        UI.error("  ❌ v1 locs: HTTP #{code} #{errs}")
      end
    end
  end

  desc "One-shot probe: test which relationship type Apple accepts for inAppPurchaseLocalizations"
  lane :iap_type_probe do
    require "net/http"
    require "uri"
    require "json"
    require "openssl"
    require "jwt"

    private_key = OpenSSL::PKey::EC.new(File.read(KEY_PATH))
    now   = Time.now.to_i
    token = JWT.encode(
      { iss: ISSUER_ID, iat: now, exp: now + 1200, aud: "appstoreconnect-v1" },
      private_key, "ES256", { kid: KEY_ID }
    )
    base    = "https://api.appstoreconnect.apple.com/v1"
    headers = { "Authorization" => "Bearer #{token}", "Content-Type" => "application/json" }

    asc_get = lambda do |path|
      uri  = URI("#{base}#{path}")
      req  = Net::HTTP::Get.new(uri)
      headers.each { |k, v| req[k] = v }
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      JSON.parse(resp.body)
    end

    iap_resp = asc_get.call("/apps/#{APPLE_ID}/inAppPurchasesV2?limit=1")
    iap = (iap_resp["data"] || []).first
    next UI.error("No IAPs found") unless iap

    iap_id = iap["id"]
    UI.message("Testing localization create for IAP id=#{iap_id} type=#{iap['type']}")
    UI.message("IAP relationships: #{JSON.generate(iap['relationships'] || {})}")
    UI.message("IAP links: #{JSON.generate(iap['links'] || {})}")

    %w[inAppPurchasesV2 inAppPurchaseV2 inAppPurchases inAppPurchase].each do |try_type|
      body = {
        data: {
          type: "inAppPurchaseLocalizations",
          attributes: { locale: "en-US", name: "Starter Pack", description: "Test" },
          relationships: {
            inAppPurchaseV2: { data: { type: try_type, id: iap_id } }
          }
        }
      }
      uri  = URI("#{base}/inAppPurchaseLocalizations")
      req  = Net::HTTP::Post.new(uri)
      headers.each { |k, v| req[k] = v }
      req.body = JSON.generate(body)
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      parsed = begin; JSON.parse(resp.body); rescue; {}; end
      detail = (parsed["errors"] || []).map { |e| e["code"] || e["detail"] }.first || parsed.dig("data", "id") || ""
      UI.message("  type=#{try_type.ljust(20)} → HTTP #{resp.code}  #{detail}")
      break if resp.code.to_i == 201
    end
  end

