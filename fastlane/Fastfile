  desc "Debug builds API response"
  lane :debug_builds do
    require "net/http"
    require "uri"
    require "json"
    require "openssl"
    require "jwt"

    private_key = OpenSSL::PKey::EC.new(File.read(KEY_PATH))
    now   = Time.now.to_i
    token = JWT.encode(
      { iss: ISSUER_ID, iat: now, exp: now + 1200, aud: "appstoreconnect-v1" },
      private_key, "ES256", { kid: KEY_ID }
    )
    base    = "https://api.appstoreconnect.apple.com/v1"
    headers = { "Authorization" => "Bearer #{token}", "Content-Type" => "application/json" }

    [
      "/builds?filter%5Bapp%5D=#{APPLE_ID}&filter%5Bplatform%5D=IOS&limit=10&sort=-version",
      "/builds?filter%5Bapp%5D=#{APPLE_ID}&limit=10",
      "/apps/#{APPLE_ID}/builds?limit=10"
    ].each do |path|
      uri  = URI("#{base}#{path}")
      req  = Net::HTTP::Get.new(uri)
      headers.each { |k, v| req[k] = v }
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      data = JSON.parse(resp.body)
      count = (data["data"] || []).size
      UI.message("GET #{path}")
      UI.message("  HTTP #{resp.code} → #{count} build(s)")
      (data["data"] || []).each do |b|
        UI.message("    build=#{b.dig('attributes','version')} state=#{b.dig('attributes','processingState')} expired=#{b.dig('attributes','expired')}")
      end
      if data["errors"]
        UI.error("  Errors: #{data['errors'].map { |e| e['detail'] }.join('; ')}")
      end
    end
  end

  desc "Check builds available in TestFlight and review submission items"
  lane :check_builds do
    require "net/http"
    require "uri"
    require "json"
    require "openssl"
    require "jwt"

    private_key = OpenSSL::PKey::EC.new(File.read(KEY_PATH))
    now   = Time.now.to_i
    token = JWT.encode(
      { iss: ISSUER_ID, iat: now, exp: now + 1200, aud: "appstoreconnect-v1" },
      private_key, "ES256", { kid: KEY_ID }
    )
    base    = "https://api.appstoreconnect.apple.com/v1"
    headers = { "Authorization" => "Bearer #{token}", "Content-Type" => "application/json" }
    asc_get = lambda do |path|
      uri  = URI("#{base}#{path}")
      req  = Net::HTTP::Get.new(uri)
      headers.each { |k, v| req[k] = v }
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      JSON.parse(resp.body)
    end
    asc_post = lambda do |path, body|
      uri  = URI("#{base}#{path}")
      req  = Net::HTTP::Post.new(uri)
      headers.each { |k, v| req[k] = v }
      req.body = JSON.generate(body)
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      parsed = begin; JSON.parse(resp.body); rescue; {}; end
      [resp.code.to_i, parsed]
    end

    UI.message("\n=== LATEST BUILDS ===")
    builds_resp = asc_get.call("/builds?filter%5Bapp%5D=#{APPLE_ID}&filter%5Bplatform%5D=IOS&limit=10&sort=-version")
    (builds_resp["data"] || []).each do |b|
      UI.message("  build=#{b.dig('attributes','version').to_s.rjust(3)} expired=#{b.dig('attributes','expired')} state=#{b.dig('attributes','processingState')} id=#{b['id']}")
    end

    UI.message("\n=== CURRENT REVIEW SUBMISSIONS + ITEMS ===")
    subs_resp = asc_get.call("/apps/#{APPLE_ID}/reviewSubmissions?limit=10")
    (subs_resp["data"] || []).each do |sub|
      sub_id    = sub["id"]
      sub_state = sub.dig("attributes", "state")
      UI.message("  Submission #{sub_id} state=#{sub_state}")
      items_resp = asc_get.call("/reviewSubmissions/#{sub_id}/items")
      items = items_resp["data"] || []
      if items.empty?
        UI.message("    (no items)")
      else
        items.each { |i| UI.message("    item type=#{i['type']} id=#{i['id']} state=#{i.dig('attributes','state')}") }
      end
    end

    UI.message("\n=== TRY: Submit rejected v1.0 via deprecated appStoreVersionSubmissions ===")
    version_id = "8cfe8e4c-53ba-4097-abb5-134f0358a255"
    code, resp = asc_post.call("/appStoreVersionSubmissions", {
      data: {
        type: "appStoreVersionSubmissions",
        relationships: {
          appStoreVersion: { data: { type: "appStoreVersions", id: version_id } }
        }
      }
    })
    UI.message("  → HTTP #{code}")
    if code == 201
      UI.success("  ✅ Submitted via deprecated endpoint!")
    else
      errs = (resp["errors"] || []).map { |e| "#{e['code']}: #{e['detail']}" }.join("; ")
      UI.message("  → #{errs}")
    end
  end

  desc "Check current state of versions and IAPs"
  lane :check_state do
    require "net/http"
    require "uri"
    require "json"
    require "openssl"
    require "jwt"

    private_key = OpenSSL::PKey::EC.new(File.read(KEY_PATH))
    now   = Time.now.to_i
    token = JWT.encode(
      { iss: ISSUER_ID, iat: now, exp: now + 1200, aud: "appstoreconnect-v1" },
      private_key, "ES256", { kid: KEY_ID }
    )
    base    = "https://api.appstoreconnect.apple.com/v1"
    headers = { "Authorization" => "Bearer #{token}", "Content-Type" => "application/json" }
    asc_get = lambda do |path|
      uri  = URI("#{base}#{path}")
      req  = Net::HTTP::Get.new(uri)
      headers.each { |k, v| req[k] = v }
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      JSON.parse(resp.body)
    end

    UI.message("\n=== ALL iOS VERSIONS ===")
    versions = asc_get.call("/apps/#{APPLE_ID}/appStoreVersions?filter%5Bplatform%5D=IOS&limit=10")
    (versions["data"] || []).each do |v|
      UI.message("  v#{v.dig('attributes','versionString')} | state=#{v.dig('attributes','appStoreState')} | id=#{v['id']}")
    end

    UI.message("\n=== IAPs ===")
    iaps = asc_get.call("/apps/#{APPLE_ID}/inAppPurchasesV2?limit=50")
    (iaps["data"] || []).each do |iap|
      pid   = iap.dig("attributes", "productId")
      state = iap.dig("attributes", "state")
      UI.message("  #{pid.to_s.ljust(22)} state=#{state}  id=#{iap['id']}")
    end

    UI.message("\n=== REVIEW SUBMISSIONS ===")
    subs = asc_get.call("/apps/#{APPLE_ID}/reviewSubmissions?limit=10")
    if (subs["data"] || []).empty?
      UI.message("  (none)")
    else
      (subs["data"] || []).each do |s|
        UI.message("  id=#{s['id']} state=#{s.dig('attributes','state')} platform=#{s.dig('attributes','platform')}")
      end
    end
  end

  desc "Create v1.1, cancel old submissions, attach latest build + all 3 IAPs, and submit for App Store review"
  lane :submit_v11 do
    require "net/http"
    require "uri"
    require "json"
    require "openssl"
    require "jwt"

    private_key = OpenSSL::PKey::EC.new(File.read(KEY_PATH))
    now   = Time.now.to_i
    token = JWT.encode(
      { iss: ISSUER_ID, iat: now, exp: now + 1200, aud: "appstoreconnect-v1" },
      private_key, "ES256", { kid: KEY_ID }
    )
    base    = "https://api.appstoreconnect.apple.com/v1"
    headers = { "Authorization" => "Bearer #{token}", "Content-Type" => "application/json" }

    asc_get = lambda do |path|
      uri  = URI("#{base}#{path}")
      req  = Net::HTTP::Get.new(uri)
      headers.each { |k, v| req[k] = v }
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      JSON.parse(resp.body)
    end
    asc_post = lambda do |path, body|
      uri  = URI("#{base}#{path}")
      req  = Net::HTTP::Post.new(uri)
      headers.each { |k, v| req[k] = v }
      req.body = JSON.generate(body)
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      parsed = begin; JSON.parse(resp.body); rescue; {}; end
      [resp.code.to_i, parsed]
    end
    asc_patch = lambda do |path, body|
      uri  = URI("#{base}#{path}")
      req  = Net::HTTP::Patch.new(uri)
      headers.each { |k, v| req[k] = v }
      req.body = JSON.generate(body)
      resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      parsed = begin; JSON.parse(resp.body); rescue; {}; end
      [resp.code.to_i, parsed]
    end

    # 1. Find latest VALID non-expired build
    UI.message("Finding latest valid build...")
    builds_resp = asc_get.call("/builds?filter%5Bapp%5D=#{APPLE_ID}&limit=20&sort=-version")
    all_builds = builds_resp["data"] || []
    all_builds.each do |b|
      UI.message("  build #{b.dig('attributes','version').to_s.rjust(3)} state=#{b.dig('attributes','processingState')} expired=#{b.dig('attributes','expired')} id=#{b['id']}")
    end
    build = all_builds.find { |b| b.dig("attributes", "processingState") == "VALID" && !b.dig("attributes", "expired") }
    unless build
      UI.error("No valid non-expired build found. Run: bundle exec fastlane beta")
      next
    end
    build_id  = build["id"]
    build_num = build.dig("attributes", "version")
    UI.success("Using build #{build_num} (id: #{build_id})")

    # 2. Check IAP states
    UI.message("Checking IAP states...")
    known_ids = %w[treats_starter_599 treats_plus_1199 treats_pro_2499]
    iap_resp  = asc_get.call("/apps/#{APPLE_ID}/inAppPurchasesV2?limit=50")
    our_iaps  = (iap_resp["data"] || []).select { |i| known_ids.include?(i.dig("attributes", "productId")) }
    our_iaps.each { |i| UI.message("  #{i.dig('attributes','productId')} state=#{i.dig('attributes','state')}") }
    not_ready = our_iaps.reject { |i| %w[READY_TO_SUBMIT WAITING_FOR_REVIEW IN_REVIEW APPROVED READY_FOR_SALE].include?(i.dig("attributes", "state")) }
    if not_ready.any?
      UI.error("IAPs not ready: #{not_ready.map { |i| "#{i.dig('attributes','productId')}=#{i.dig('attributes','state')}" }.join(', ')}")
      UI.error("Set USD pricing in App Store Connect for the missing IAPs, then re-run.")
      next
    end
    UI.success("All #{our_iaps.size} IAPs ready ✅")

    # 3. Cancel ALL open review submissions FIRST (required before creating a new version)
    UI.message("Cleaning up all open review submissions...")
    subs_resp0 = asc_get.call("/apps/#{APPLE_ID}/reviewSubmissions?limit=10")
    (subs_resp0["data"] || []).each do |sub|
      sub_state = sub.dig("attributes", "state") || ""
      next unless %w[UNRESOLVED_ISSUES READY_FOR_REVIEW].include?(sub_state)
      sub_id = sub["id"]
      UI.message("  Cancelling submission #{sub_id} (#{sub_state})...")
      code, _ = asc_patch.call("/reviewSubmissions/#{sub_id}", {
        data: { type: "reviewSubmissions", id: sub_id, attributes: { canceled: true } }
      })
      UI.message("  → HTTP #{code}")
      sleep 3
    end

    # 4. Check if v1.1 already exists in a submittable state
    all_v = asc_get.call("/apps/#{APPLE_ID}/appStoreVersions?filter%5Bplatform%5D=IOS&limit=10")
    submittable_states = %w[PREPARE_FOR_SUBMISSION WAITING_FOR_REVIEW REJECTED DEVELOPER_REJECTED]

    # Prefer v1.1 if it already exists in a submittable state; otherwise fall
    # back to any other submittable version (e.g. v1.0 in DEVELOPER_REJECTED).
    existing_version = (all_v["data"] || []).find { |v|
      v.dig("attributes", "versionString") == "1.1" &&
      submittable_states.include?(v.dig("attributes", "appStoreState"))
    }
    existing_version ||= (all_v["data"] || []).find { |v|
      submittable_states.include?(v.dig("attributes", "appStoreState"))
    }

    if existing_version
      v_str     = existing_version.dig("attributes", "versionString")
      v_state   = existing_version.dig("attributes", "appStoreState")
      version_id = existing_version["id"]
      UI.success("Using existing version #{v_str} (state: #{v_state}, id: #{version_id})")
    else
      UI.message("Creating App Store version 1.1...")
      code, v_resp = asc_post.call("/appStoreVersions", {
        data: {
          type: "appStoreVersions",
          attributes: { platform: "IOS", versionString: "1.1", releaseType: "MANUAL" },
          relationships: {
            app:   { data: { type: "apps",   id: APPLE_ID } },
            build: { data: { type: "builds", id: build_id } }
          }
        }
      })
      unless [200, 201].include?(code)
        errs = (v_resp["errors"] || []).map { |e| e["detail"] || e["title"] }.join("; ")
        UI.error("Failed to create v1.1: HTTP #{code}: #{errs}")
        next
      end
      version_id = v_resp.dig("data", "id")
      UI.success("Created v1.1 (id: #{version_id})")
    end

    # 5. Link build to v1.1
    UI.message("Linking build #{build_num} to v1.1...")
    code, link_resp = asc_patch.call("/appStoreVersions/#{version_id}", {
      data: {
        type: "appStoreVersions", id: version_id,
        relationships: { build: { data: { type: "builds", id: build_id } } }
      }
    })
    case code
    when 200, 204 then UI.success("  ✅  Build linked")
    when 409      then UI.message("  ⚠️   Build already linked")
    else
      code2, _ = asc_patch.call("/appStoreVersions/#{version_id}/relationships/build", {
        data: { type: "builds", id: build_id }
      })
      code2 == 204 || code2 == 200 ?
        UI.success("  ✅  Build linked via relationship endpoint") :
        UI.message("  ⚠️   Build link HTTP #{code}/#{code2} — continuing")
    end

    # 5. Set What's New text
    locs_resp = asc_get.call("/appStoreVersions/#{version_id}/appStoreVersionLocalizations")
    en_loc = (locs_resp["data"] || []).find { |l| l.dig("attributes", "locale") == "en-US" }
    whats_new = "Full-screen Profile and Paywall screens with back navigation. Bug fixes and performance improvements."
    if en_loc
      asc_patch.call("/appStoreVersionLocalizations/#{en_loc['id']}", {
        data: { type: "appStoreVersionLocalizations", id: en_loc["id"], attributes: { whatsNew: whats_new } }
      })
      UI.success("  ✅  Updated en-US What's New")
    else
      asc_post.call("/appStoreVersionLocalizations", {
        data: {
          type: "appStoreVersionLocalizations",
          attributes: { locale: "en-US", whatsNew: whats_new },
          relationships: { appStoreVersion: { data: { type: "appStoreVersions", id: version_id } } }
        }
      })
      UI.success("  ✅  Created en-US What's New")
    end

    # 6. Create fresh review submission
    UI.message("Creating review submission...")
    code, sub_resp = asc_post.call("/reviewSubmissions", {
      data: {
        type: "reviewSubmissions",
        attributes: { platform: "IOS" },
        relationships: { app: { data: { type: "apps", id: APPLE_ID } } }
      }
    })
    unless [200, 201].include?(code)
      errs = (sub_resp["errors"] || []).map { |e| e["detail"] || e["title"] }.join("; ")
      UI.error("Failed to create review submission: HTTP #{code}: #{errs}")
      next
    end
    submission_id = sub_resp.dig("data", "id")
    UI.success("Created submission #{submission_id}")
    sleep 2

    # 8. Add v1.1 to submission
    UI.message("Adding v1.1 to submission...")
    code, item_resp = asc_post.call("/reviewSubmissionItems", {
      data: {
        type: "reviewSubmissionItems",
        relationships: {
          reviewSubmission: { data: { type: "reviewSubmissions", id: submission_id } },
          appStoreVersion:  { data: { type: "appStoreVersions",  id: version_id } }
        }
      }
    })
    case code
    when 200, 201 then UI.success("  ✅  v1.1 added (item: #{item_resp.dig('data','id')})")
    when 409      then UI.message("  ⚠️   v1.1 already in submission")
    else
      errs = (item_resp["errors"] || []).map { |e| e["detail"] || e["title"] }.join("; ")
      UI.error("  ❌  v1.1 HTTP #{code}: #{errs}")
    end

    # 9. Add each READY_TO_SUBMIT IAP to submission
    UI.message("Adding IAPs to submission...")
    our_iaps.each do |iap|
      pid    = iap.dig("attributes", "productId")
      iap_id = iap["id"]
      next if %w[WAITING_FOR_REVIEW IN_REVIEW APPROVED READY_FOR_SALE].include?(iap.dig("attributes", "state"))
      code, item_resp = asc_post.call("/reviewSubmissionItems", {
        data: {
          type: "reviewSubmissionItems",
          relationships: {
            reviewSubmission: { data: { type: "reviewSubmissions", id: submission_id } },
            inAppPurchaseV2:  { data: { type: "inAppPurchasesV2",  id: iap_id } }
          }
        }
      })
      case code
      when 200, 201 then UI.success("  ✅  #{pid} added")
      when 409      then UI.message("  ⚠️   #{pid} already in submission")
      else
        errs = (item_resp["errors"] || []).map { |e| e["detail"] || e["title"] }.join("; ")
        UI.error("  ❌  #{pid} HTTP #{code}: #{errs}")
      end
    end

    # 10. Verify items and submit
    items = asc_get.call("/reviewSubmissions/#{submission_id}/items")["data"] || []
    UI.message("Submission has #{items.size} item(s). Submitting for review...")

    code, final_resp = asc_patch.call("/reviewSubmissions/#{submission_id}", {
      data: {
        type: "reviewSubmissions",
        id:   submission_id,
        attributes: { submitted: true }
      }
    })
    case code
    when 200, 201
      UI.success("🎉  Submitted v1.1 (build #{build_num}) + #{our_iaps.size} IAPs for App Store review!")
      UI.success("    Submission ID: #{submission_id}")
    else
      errs = (final_resp["errors"] || []).map { |e| e["detail"] || e["title"] }.join("; ")
      UI.error("❌  Submit failed: HTTP #{code}: #{errs}")
      UI.message("    #{JSON.generate(final_resp)[0..800]}")
    end
  end

end
