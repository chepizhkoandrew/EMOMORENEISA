PORT=8080
NODE_ENV=production

SUPABASE_URL=https://rbbgayxvrobzlndprcwt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

OPENAI_API_KEY=
GEMINI_API_KEY=

MODEL_CHAT=gpt-4.1
MODEL_VISION=gpt-4.1
MODEL_ANALYST=gpt-4o-mini
MODEL_TTS_GEMINI=gemini-2.5-flash-preview-tts
MODEL_TTS_OPENAI=tts-1

ENFORCE_WALLET=false

# Shared voice cache (Supabase Storage, AAC). Dedups TTS across all users.
AUDIO_CACHE_ENABLED=true
AUDIO_CACHE_BUCKET=voice-cache
AAC_BITRATE=40k

# Vertex AI image generation (Gemini 2.5 Flash Image / "nano banana") for
# memorization illustrations. Reuses the Cloud TTS service account
# (GOOGLE_TTS_CREDENTIALS) — Vertex AI must be enabled on it. Project id is read
# from the service-account JSON unless VERTEX_PROJECT_ID overrides it.
VERTEX_IMAGE_ENABLED=true
VERTEX_PROJECT_ID=
VERTEX_LOCATION=global
VERTEX_IMAGE_MODEL=gemini-2.5-flash-image
USD_PER_IMAGE=0.039

# Shared illustration cache (Supabase Storage, JPEG). Dedups images across users.
IMAGE_CACHE_ENABLED=true
IMAGE_CACHE_BUCKET=image-cache
IMAGE_JPEG_QUALITY=82
IMAGE_MAX_SIZE=512

USD_PER_MTOK_IN_CHAT=2.0
USD_PER_MTOK_OUT_CHAT=8.0
USD_PER_MTOK_IN_ANALYST=0.15
USD_PER_MTOK_OUT_ANALYST=0.6
USD_PER_MIN_TTS_GEMINI=0.0048
USD_PER_MIN_TTS_OPENAI=0.015
INFRA_OVERHEAD=0.15
TARGET_MARGIN=5.0
APPLE_FEE=0.15
USD_PER_TREAT=0.01
STREETVIEW_FREE_PER_DAY=20
TRIAL_BUDGET_USD=0.05

CIRCUIT_PER_USER_DAILY_USD=5.0
CIRCUIT_GLOBAL_DAILY_USD=200.0
